# LLM (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
MAX_TOKENS=8192
TEMPERATURE=0.7

# Seedstr
SEEDSTR_API_KEY=mj_
SEEDSTR_API_URL=https://www.seedstr.io/api/v2

# Wallet
WALLET_ADDRESS=
WALLET_TYPE=ETH

# Agent behavior
MIN_BUDGET=0
POLL_INTERVAL=5
USE_WEBSOCKET=false
PUSHER_KEY=
PUSHER_CLUSTER=us2

# Engine server
PORT=8787
ENGINE_AUTO_START=true
ENGINE_OUTPUT_DIR=engine/runs/current
ENGINE_ARCHIVE_DIR=engine/runs/archives
ENGINE_CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
DEBUG=false
